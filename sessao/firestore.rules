rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuth() {
      return request.auth != null;
    }
    function isMember(coupleData) {
      return coupleData.uid1 == request.auth.uid || coupleData.uid2 == request.auth.uid;
    }
    function coupleData(coupleId) {
      return get(/databases/$(database)/documents/couples/$(coupleId)).data;
    }
    function reviewOwnerName(coupleData) {
      if (request.auth.uid == coupleData.uid1) return coupleData.name1;
      if (request.auth.uid == coupleData.uid2) return coupleData.name2;
      return null;
    }
    function ownReviewUpdate(coupleData) {
      let owner = reviewOwnerName(coupleData);
      return owner != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["reviews"])
        && request.resource.data.reviews.keys().hasOnly(resource.data.reviews.keys().union([owner]))
        && request.resource.data.reviews.keys().hasAll(resource.data.reviews.keys())
        && request.resource.data.reviews[owner] != null;
    }

    // Couples collection
    match /couples/{coupleId} {
      // Any authenticated user can read (needed for invite code lookup)
      allow read: if isAuth();

      // Create: only the first user (uid1) can create their own couple
      allow create: if isAuth() && request.resource.data.uid1 == request.auth.uid;

      // Update: uid1 can update anything; someone joining sets uid2 if it's currently null
      allow update: if isAuth() && (
        resource.data.uid1 == request.auth.uid ||
        resource.data.uid2 == request.auth.uid ||
        (resource.data.uid2 == null && request.resource.data.uid2 == request.auth.uid)
      );

      // Delete: only uid1 can delete
      allow delete: if isAuth() && resource.data.uid1 == request.auth.uid;

      // Watched subcollection
      match /watched/{entryId} {
        allow read: if isAuth() && isMember(coupleData(coupleId));
        allow create: if isAuth() && isMember(coupleData(coupleId)) && (
          !('reviews' in request.resource.data)
          || request.resource.data.reviews.keys().hasOnly([reviewOwnerName(coupleData(coupleId))])
        );
        allow update: if isAuth() && isMember(coupleData(coupleId)) && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["reviews"])
          || ownReviewUpdate(coupleData(coupleId))
        );
        allow delete: if isAuth() && isMember(coupleData(coupleId));
      }

      // Watchlist subcollection
      match /watchlist/{entryId} {
        allow read, write: if isAuth() && isMember(coupleData(coupleId));
      }
    }
  }
}
